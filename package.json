{
  "name": "backyard-bullies-site",
  "version": "1.0.0",
  "private": true,
  "description": "Backyard Bullies Wrestling Club website",
  "scripts": {
    "build:css": "tailwindcss -i ./src/input.css -o ./assets/tailwind.css --minify",
    "watch:css": "tailwindcss -i ./src/input.css -o ./assets/tailwind.css --watch",
    "lint": "npm run lint:html && npm run lint:css && npm run lint:content && npm run lint:redirects",
    "lint:html": "html-validate index.html \"parents-night-out/**/*.html\" \"homeschool-functional-fitness/**/*.html\" \"scholarship/**/*.html\"",
    "lint:css": "stylelint \"src/**/*.css\"",
    "lint:content": "node scripts/check-content.mjs",
    "lint:redirects": "node scripts/sync-cloudflare-redirects.mjs --check",
    "sync:redirects": "node scripts/sync-cloudflare-redirects.mjs --sync",
    "a11y": "bash scripts/a11y-audit.sh",
    "a11y:lint": "bash scripts/a11y-audit.sh --lint-only",
    "a11y:doctor": "bash tests/a11y/scripts/a11y-doctor.sh",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@double-great/stylelint-a11y": "^3.4.15",
    "@playwright/test": "^1.61.0",
    "html-validate": "^11.5.3",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "pa11y-ci": "^4.1.1",
    "prettier": "^3.8.4",
    "stylelint": "^17.13.0",
    "stylelint-config-standard": "^40.0.0",
    "tailwindcss": "^3.4.17"
  },
  "lint-staged": {
    "src/**/*.css": [
      "stylelint --fix",
      "prettier --write"
    ],
    "*.{js,mjs,cjs,json,md,yml,yaml}": [
      "prettier --write"
    ],
    "index.html": [
      "html-validate",
      "node scripts/check-content.mjs"
    ],
    "parents-night-out/**/*.html": [
      "html-validate"
    ],
    "homeschool-functional-fitness/**/*.html": [
      "html-validate"
    ],
    "scholarship/**/*.html": [
      "html-validate"
    ]
  }
}
